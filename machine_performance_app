########################################################################
# ISO 22514-3:2020 — Machine Performance Study Shiny App
#
# Implements the procedure described in ISO 22514-3:2020(E):
#   Statistical methods in process management — Capability and
#   performance — Part 3: Machine performance studies for measured
#   data on discrete parts.
#
# Covers:
#   Clause 5  - Pre-condition checks (n >= 30, warning if n < 100)
#   Clause 6  - Data collection / traceability
#   Clause 7.2 - Run chart
#   Clause 7.3 - Histogram / tally chart, pattern check (with fitted
#                normal curve and spec limit overlay)
#   Clause 7.4 - Probability plot (+ normality test)
#   Clause 7.5 - Special cases (skew / bimodal) flagged, percentile method
#   Clause 7.6 - Machine performance indices (Pm, PmkU, PmkL, Pmk)
#   Clause 8   - Reporting, confidence intervals, proportion out of spec
#
# Required packages: shiny, ggplot2, DT
########################################################################

library(shiny)
library(ggplot2)
library(DT)

# ---------------------------------------------------------------------
# Helper functions implementing the formulas from the standard
# ---------------------------------------------------------------------

# 7.6.2 Normal-distribution index formulas
calc_indices_normal <- function(xbar, s, LSL, USL) {
  Pm    <- NA_real_
  PmkU  <- NA_real_
  PmkL  <- NA_real_
  
  if (!is.na(LSL) && !is.na(USL)) {
    Pm <- (USL - LSL) / (6 * s)
  }
  if (!is.na(USL)) {
    PmkU <- (USL - xbar) / (3 * s)
  }
  if (!is.na(LSL)) {
    PmkL <- (xbar - LSL) / (3 * s)
  }
  Pmk <- suppressWarnings(min(c(PmkU, PmkL), na.rm = TRUE))
  if (is.infinite(Pmk)) Pmk <- NA_real_
  
  list(Pm = Pm, PmkU = PmkU, PmkL = PmkL, Pmk = Pmk)
}

# 7.6.1 Percentile-based index formulas (for non-normal / skewed / bimodal data)
# Uses empirical percentiles X0.135%, X50%, X99.865% as estimators of the
# corresponding distribution percentiles referenced in 7.5.1 / 7.5.2.
calc_indices_percentile <- function(x, LSL, USL) {
  q <- quantile(x, probs = c(0.00135, 0.5, 0.99865), type = 6, na.rm = TRUE)
  X0135  <- unname(q[1])
  X50    <- unname(q[2])
  X99865 <- unname(q[3])
  
  Pm   <- NA_real_
  PmkU <- NA_real_
  PmkL <- NA_real_
  
  if (!is.na(LSL) && !is.na(USL)) {
    Pm <- (USL - LSL) / (X99865 - X0135)
  }
  if (!is.na(USL)) {
    PmkU <- (USL - X50) / (X99865 - X50)
  }
  if (!is.na(LSL)) {
    PmkL <- (X50 - LSL) / (X50 - X0135)
  }
  Pmk <- suppressWarnings(min(c(PmkU, PmkL), na.rm = TRUE))
  if (is.infinite(Pmk)) Pmk <- NA_real_
  
  list(Pm = Pm, PmkU = PmkU, PmkL = PmkL, Pmk = Pmk,
       X0135 = X0135, X50 = X50, X99865 = X99865)
}

# 8.2.2 Approximate (1 - alpha) confidence intervals for normal-based indices
calc_ci_normal <- function(n, Pm, PmkU, PmkL, Pmk, alpha) {
  z <- qnorm(1 - alpha / 2)
  
  ci_Pm <- c(NA_real_, NA_real_)
  if (!is.na(Pm)) {
    chi_lo <- qchisq(alpha / 2, df = n - 1)
    chi_hi <- qchisq(1 - alpha / 2, df = n - 1)
    ci_Pm <- Pm * sqrt(c(chi_lo, chi_hi) / (n - 1))
  }
  
  ci_generic <- function(P) {
    if (is.na(P)) return(c(NA_real_, NA_real_))
    se <- sqrt(1 / (9 * n) + P^2 / (2 * (n - 1)))
    P + c(-1, 1) * z * se
  }
  
  list(
    Pm   = ci_Pm,
    PmkU = ci_generic(PmkU),
    PmkL = ci_generic(PmkL),
    Pmk  = ci_generic(Pmk)
  )
}

# Estimated proportion out of specification (equivalent to Table A.1 lookup,
# computed directly from the normal distribution rather than via the table).
calc_prop_out_of_spec <- function(xbar, s, LSL, USL) {
  p_low  <- if (!is.na(LSL)) pnorm(LSL, mean = xbar, sd = s) else 0
  p_high <- if (!is.na(USL)) pnorm(USL, mean = xbar, sd = s, lower.tail = FALSE) else 0
  p_low + p_high
}

# 7.3.4 Suggested number of classes (~sqrt(n), rounded, bounded 5-20 per 7.3.4)
suggest_classes <- function(n) {
  k <- round(sqrt(n))
  min(max(k, 5), 20)
}

