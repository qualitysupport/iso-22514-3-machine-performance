  sidebarLayout(
    
    sidebarPanel(
      width = 3,
      
      textInput("process_name", "Process Name",
                value = "Shaft Diameter - Machine Performance Study"),
      
      hr(),
      strong("Specification Limits"),
      numericInput("usl",    "Upper Spec Limit (USL)", value = 25.10, step = 0.01),
      numericInput("lsl",    "Lower Spec Limit (LSL)", value = 24.90, step = 0.01),
      numericInput("target", "Target Value",            value = 25.00, step = 0.01),
      
      hr(),
      strong("Environment"),
      numericInput("temperature", "Temperature (°C)", value = 20.3, step = 0.1),
      numericInput("humidity",    "Humidity (%RH)",   value = 48.2, step = 0.1),
      
      hr(),
      strong("Acceptance Threshold"),
      numericInput("threshold", "Min Pm / Pmk", value = 1.67, step = 0.01),
      tags$p("Default 1.67. Some customers require 2.00.",
             style = "font-size:0.75rem; color:grey;"),
      
      hr(),
      strong("Part Measurements"),
      tags$p("Paste comma-separated values (up to 50):",
             style = "font-size:0.8rem; color:grey; margin-bottom:4px;"),
      textAreaInput("part_data", label = NULL, rows = 6,
                    value = "25.01,24.98,25.02,25.00,24.99,25.03,24.97,25.01,25.04,24.98,25.02,25.00,24.99,25.01,24.96,25.03,25.00,24.98,25.02,25.01,24.99,25.03,24.97,25.00,25.02,24.98,25.01,25.03,24.99,25.00,25.02,24.97,25.01,24.99,25.03,25.00,24.98,25.02,25.01,24.99,25.00,25.03,24.98,25.01,24.97,25.02,25.00,24.99,25.01,25.02"),
      textOutput("part_count_label"),
      
      br(),
      actionButton("run", "Calculate", class = "btn-primary", width = "100%"),
      
      hr(),
      strong("Save / Load"),
      br(), br(),
      downloadButton("save_json", "Save as JSON", style = "width:100%;"),
      br(), br(),
      fileInput("load_json", "Upload JSON", accept = ".json",
