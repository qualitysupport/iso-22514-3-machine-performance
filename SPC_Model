), na.rm = TRUE)


#Machine performance indices per ISO 22514-3:2020 and AIAG/VDA SPC Yellow Volume (February 2026).
#Pm: spread index only, does not penalize for mean location.
#Pmk: location index, penalizes mean shift toward either specification limit.
#Pmk is always <= Pm. The gap between them indicates how well the mean is centered.
Pm <- (upper_specification_limit - lower_specification_limit) / (6 * machine_test_variation_standard_deviation)

Pmk <- min(
  (upper_specification_limit - machine_test_mean) / (3 * machine_test_variation_standard_deviation),
  (machine_test_mean - lower_specification_limit) / (3 * machine_test_variation_standard_deviation)
)


#Acceptance threshold check.
#Default threshold is 1.67 per AIAG/VDA SPC Yellow Volume.
#Some customers require 2.00. Confirm against your customer PPAP requirements.
acceptance_threshold <- 1.67

Pm_pass  <- Pm  >= acceptance_threshold
Pmk_pass <- Pmk >= acceptance_threshold

#Results summary
